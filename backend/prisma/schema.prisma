generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  phone      String?  @unique
  subscribed Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  password   String?
  roleName   String   @default("user")
  role       Roles    @relation(fields: [roleName], references: [name])
  organizationId String?

  organization Organizations []
}
model Organizations {
  id        String   @id @default(uuid())
  name      String   @unique
  subscriptionType   SubscriptionType   @default(basic)
  isActive  Boolean  @default(true)
  subscriptionStartDate DateTime?
  subscriptionValidUntil  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId String?

  user User? @relation(fields: [userId], references: [id])
  cameras   Cameras[]
  subscribers Subscribers[]
}

model Subscribers {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  phone      String @unique
  PhoneVerificationCode String?
  emailVerificationCode String?
  isPhoneVerified Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  isActive   Boolean  @default(true)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  organizationId String?
  @@unique([email, organizationId])
  @@unique([phone, organizationId])
  organization   Organizations? @relation(fields: [organizationId], references: [id]) 
}

model Roles {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model AnimalLogs {
  id         String   @id @default(uuid())
  animalId   String
  cameraId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isVerified Boolean  @default(true)
  confidence Float
  status     String   @default("PENDING")
  animal     Animals  @relation(fields: [animalId], references: [id])
  camera     Cameras  @relation(fields: [cameraId], references: [id])
}

model Alerts {
  id         String   @id @default(uuid())
  cameraId   String
  message    String
  status     String   @default("SENT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  animalName String
  animal     Animals  @relation(fields: [animalName], references: [name])
  camera     Cameras  @relation(fields: [cameraId], references: [id])
}

model DailyReports {
  id          String   @id @default(uuid())
  date        DateTime
  count       Int
  cameraId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  speciesName String
  animal      Animals  @relation(fields: [speciesName], references: [name])

  @@unique([date, speciesName, cameraId])
}

model Animals {
  id                 String             @id @default(uuid())
  name               String             @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  conservationStatus ConservationStatus @default(endangered)
  alertPriority      AlertPriority      @default(high)
  alerts             Alerts[]
  logs               AnimalLogs[]
  reports            DailyReports[]
}

model Cameras {
  id        String       @id @default(uuid())
  name      String
  location  String
  streamUrl String
  organizationId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  isActive  Boolean      @default(true)

  organization Organizations @relation(fields: [organizationId], references: [id])
  alerts    Alerts[]
  logs      AnimalLogs[]
}

enum ConservationStatus {
  endangered
  vulnerable
  protected
}

enum AlertPriority {
  low
  medium
  high
}

enum SubscriptionType {
  basic
  premium
  enterprise
}
