{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "outDir": "./build",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": ["./@types", "./node_modules/@types"],
    "types": ["node", "express"]
  },
  "include": ["src/**/*", "generated/**/*.ts", "prisma.config.ts", "@types/**/*"],
  "exclude": ["node_modules"]
}